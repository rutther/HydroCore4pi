#!/bin/sh
set -eu

ENV_FILE=/etc/hydrocore/hydrocore.env
if [ -r "$ENV_FILE" ]; then
  # shellcheck disable=SC1090
  . "$ENV_FILE"
fi

PORT="${HYDROCORE_PORT:-5000}"
URL="http://127.0.0.1:${PORT}/api/v1/system/status"

if /usr/bin/python3 - "$URL" <<'PY'
import sys
import urllib.request

url = sys.argv[1]
with urllib.request.urlopen(url, timeout=8) as response:
    if response.status != 200:
        raise SystemExit(1)
PY
then
  exit 0
fi

logger -t hydrocore-watchdog "HydroCore health check failed; restarting hydrocore.service"
systemctl restart hydrocore.service
