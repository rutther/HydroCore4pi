# HydroCore runtime environment.
# This file is installed as a Debian conffile and should survive package upgrades.

HYDROCORE_HOST=0.0.0.0
HYDROCORE_PORT=5000
HYDROCORE_BIND=0.0.0.0:5000
HYDROCORE_DEBUG=0
HYDROCORE_BACKGROUND_AUTOSTART=1
HYDROCORE_OUTPUT_SAFE_ON_START=1
PYTHONUNBUFFERED=1

HYDROCORE_DATA_DIR=/var/lib/hydrocore
HYDROCORE_CONFIG_DIR=/etc/hydrocore
HYDROCORE_DEFAULTS_DIR=/usr/share/hydrocore/defaults
HYDROCORE_PROTOCOL_DIR=/opt/hydrocore/protocols
HYDROCORE_USER_PROTOCOL_DIR=/var/lib/hydrocore/protocols_user
HYDROCORE_POLL_PLAN_FILE=/var/lib/hydrocore/config_poll_plan.json
HYDROCORE_KIOSK_URL=http://127.0.0.1:5000/ui/
HYDROCORE_KIOSK_COMPOSITOR=labwc
HYDROCORE_OSK_ENABLED=1
HYDROCORE_OSK_COMMAND=squeekboard
